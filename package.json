  },
  "homepage": "https://github.com/anineco/web-map-apps#readme",
  "devDependencies": {
    "@babel/core": "^7.12.10",
    "@babel/preset-env": "^7.12.11",
    "cssnano": "^4.1.10"
  },
  "dependencies": {
    "dotenv": "^8.2.0",
    "ga-gtag": "^1.0.1",
    "ol": "^6.5.0",
    "ol-popup": "^4.0.0",
    "promise-polyfill": "^8.2.0",
